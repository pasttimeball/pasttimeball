---
import Base from '../layouts/Base.astro';
---
<Base
  title="Subscribe"
  description="Get new Past Time Ball clippings by email, straight from the archives to your inbox."
>
  <article class="prose">
    <h1>Get the clippings by email</h1>
    <p>
      New clippings land here every few days. If you would rather they come to you, leave an
      address and each new find will arrive by email, signed from the cheap seats. No filler,
      nothing but old baseball. Unsubscribe anytime and no hard feelings.
    </p>
    <form
      action="https://buttondown.com/api/emails/embed-subscribe/pasttimeball"
      method="post"
      class="subscribe-form"
    >
      <label for="bd-email">Email address</label>
      <input type="email" name="email" id="bd-email" required placeholder="you@example.com" />
      <button type="submit">Subscribe</button>
    </form>
    <p>
      Prefer a feed reader? The <a href="/rss.xml">RSS feed</a> carries the same clippings.
      Prefer a scroll? The clippings also make the rounds on
      <a href="https://www.instagram.com/pasttimeball/">Instagram</a>.
    </p>
  </article>
</Base>

<style>
  .subscribe-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin: 1.5rem 0;
  }
  .subscribe-form label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
  .subscribe-form input[type='email'] {
    flex: 1 1 16rem;
    padding: 0.6rem 0.8rem;
    font: inherit;
    border: 2px solid var(--ink, #1b1b19);
    border-radius: 4px;
    background: #fff;
  }
  .subscribe-form button {
    padding: 0.6rem 1.4rem;
    font: inherit;
    font-weight: 700;
    color: #fff;
    background: var(--accent, #2d5a3d);
    border: 2px solid var(--accent, #2d5a3d);
    border-radius: 4px;
    cursor: pointer;
  }
  .subscribe-form button:hover {
    background: var(--ink, #1b1b19);
    border-color: var(--ink, #1b1b19);
  }
</style>
